        math.clamp(myCountryData:GetAttribute("money") / 100000, 0, 1),
        math.clamp(myCountryData:GetAttribute("manpower") / 100000, 0, 1),
        math.clamp(myCountryData:GetAttribute("politicalPower") / 500, 0, 1),
        math.clamp(myCitiesCount / 50, 0, 1),
        myPower / (enemyPower + myPower + 1),
        allyPower / (enemyPower + allyPower + 1),
        math.clamp(enemyCount / 5, 0, 1),
        math.clamp(neighborCount / 10, 0, 1),
        math.clamp((justifications and #justifications:GetChildren() or 0) / 5, 0, 1),
        conquestProgress,
        moneyVel,
        manVel,
        alliedCityRatio
    }
    
    -- Forward Pass
    local outputs = NeuralStrategyNet:Forward(inputs)
    
    -- Find max strategy probability
    local maxVal = -1
    local stratIndex = 1
    for i, v in ipairs(outputs) do
        if v > maxVal then
            maxVal = v
            stratIndex = i
        end
    end
    
    local stratNames = {"BLITZ", "DEFEND", "EXPAND", "CONSOLIDATE"}
    local oldStrategy = World.Strategy
    World.Strategy = stratNames[stratIndex]
    
    -- Online Training with Adam Optimizer
    local targets = self:GetExpertHeuristics()
    NeuralStrategyNet:Backward(targets, 0.01)
    
    if oldStrategy ~= World.Strategy then
        Stats.StrategySwitches = Stats.StrategySwitches + 1
        Log("🧠", "Neural Strategy Switch: " .. oldStrategy .. " → " .. World.Strategy)
    end
    
    return World.Strategy
end

function Brain:FindBestAlly()
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    local justifications = myCountryData and myCountryData.Diplomacy:FindFirstChild("Justifications")
    
    local candidates = {}
    for name, data in pairs(World.Countries) do
        if name == World.MyCountry then continue end
        if data.CityCount == 0 then continue end
        
        local isAlly = false
        for _, a in ipairs(World.MyAllies) do
            if a == name then isAlly = true break end
        end
        if isAlly then continue end
        
        local isEnemy = false
        for _, e in ipairs(World.MyEnemies) do
            if e == name then isEnemy = true break end
        end
        if isEnemy then continue end
        
        -- Do not ally with countries we are justifying against
        local isJustifying = justifications and justifications:FindFirstChild(name)
        if isJustifying then continue end
        
        -- Max 3 alliances limit check for target
        if #data.Allies >= 3 then continue end
        
        local score = 0
        score = score + data.Power * 0.5
        if data.IsPlayer then score = score + 20 end
        
        table.insert(candidates, {Country = name, Score = score})
    end
    table.sort(candidates, function(a, b) return a.Score > b.Score end)
    return candidates
end

