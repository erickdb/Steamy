-- DYNAMIC TARGET SCANNING & GEOPOLITICS
-- ══════════════════════════════════════════════════════════════

local function GetLandNeighbors()
    local neighborsList = {}
    local map = game.Workspace:FindFirstChild("Map")
    if not map then return {} end
    
    local myColorHex = World.MyColor:ToHex()
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    
    for _, tile in ipairs(map:GetChildren()) do
        if tile:IsA("BasePart") and not tile.Name:match("^Sea") then
            if tile.Color == World.MyColor then
                local nList = neighbours[tile]
                if nList then
                    for _, n in ipairs(nList) do
                        if not n.Name:match("^Sea") then
                            local nColorHex = n.Color:ToHex()
                            if nColorHex ~= myColorHex then
                                local neighborCountry = MapData.colorToCountry[nColorHex]
                                if neighborCountry and neighborCountry ~= World.MyCountry then
                                    local isAllyOrPuppet = false
                                    for _, a in ipairs(World.MyAllies) do
                                        if a == neighborCountry then isAllyOrPuppet = true break end
                                    end
                                    if myCountryData then
                                        local puppets = myCountryData.Diplomacy:FindFirstChild("Puppets")
                                        if puppets and puppets:FindFirstChild(neighborCountry) then
                                            isAllyOrPuppet = true
                                        end
                                        if myCountryData:GetAttribute("puppetOf") == neighborCountry then
                                            isAllyOrPuppet = true
                                        end
                                    end
                                    
                                    if not isAllyOrPuppet then
                                        local cFolder = RS.Countries:FindFirstChild(neighborCountry)
                                        if cFolder and not cFolder:GetAttribute("isDead") then
                                            neighborsList[neighborCountry] = cFolder
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    local arr = {}
    for name, folder in pairs(neighborsList) do
        table.insert(arr, {Name = name, Folder = folder})
    end
    return arr
end

local function GetPotentialTargets()
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return {} end
    
    local neighbors = GetLandNeighbors()
    if #neighbors > 0 then
        return neighbors
    end
    
    local targets = {}
    for _, c in ipairs(RS.Countries:GetChildren()) do
        if c:IsA("ObjectValue") and c.Name ~= World.MyCountry and not c:GetAttribute("isDead") then
            local isAllyOrPuppet = false
            for _, a in ipairs(World.MyAllies) do
                if a == c.Name then isAllyOrPuppet = true break end
            end
            local puppets = myCountryData.Diplomacy:FindFirstChild("Puppets")
            if puppets and puppets:FindFirstChild(c.Name) then
                isAllyOrPuppet = true
            end
            if myCountryData:GetAttribute("puppetOf") == c.Name then
                isAllyOrPuppet = true
            end
            
            if not isAllyOrPuppet then
                table.insert(targets, {Name = c.Name, Folder = c})
            end
        end
    end
    
    table.sort(targets, function(a, b)
        local aCities = a.Folder.Cities and #a.Folder.Cities:GetChildren() or 0
        local bCities = b.Folder.Cities and #b.Folder.Cities:GetChildren() or 0
        return aCities < bCities
    end)
    
    return targets
end

local function GetWorldConquestPercentage()
    local map = game.Workspace:FindFirstChild("Map")
    if not map then return 0 end
    
    local totalLandTiles = 0
    local myLandTiles = 0
    
    for _, tile in ipairs(map:GetChildren()) do
        if tile:IsA("BasePart") and not tile.Name:match("^Sea") then
            totalLandTiles = totalLandTiles + 1
            if tile.Color == World.MyColor then
                myLandTiles = myLandTiles + 1
            end
        end
    end
    
    if totalLandTiles == 0 then return 0 end
    return (myLandTiles / totalLandTiles) * 100
end

