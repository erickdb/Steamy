-- BFS Pathfinding helper
local function computePath(startTile, targetTile, allowedColors)
    local queue = {startTile}
    local visited = {[startTile] = true}
    local parent = {}
    
    while #queue > 0 do
        local current = table.remove(queue, 1)
        if current == targetTile then
            local path = {current}
            while parent[current] do
                current = parent[current]
                table.insert(path, 1, current)
            end
            return path
        end
        
        local nList = neighbours[current]
        if nList then
            for _, n in ipairs(nList) do
                if not visited[n] and not n.Name:match("^Sea") then
                    local hex = n.Color:ToHex()
                    local isWalkable = allowedColors[hex] or (n == targetTile)
                    if isWalkable then
                        visited[n] = true
                        parent[n] = current
                        table.insert(queue, n)
                    end
                end
            end
        end
    end
    return nil
end

