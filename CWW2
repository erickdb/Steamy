function Executor:ManageResearch()
    if not Config.AutoResearch then return end
    
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    local slots = myCountryData:FindFirstChild("ResearchSlots")
    local techs = myCountryData:FindFirstChild("Techs")
    if not slots or not techs then return end
    
    -- Auto Focus tree
    local gov = myCountryData:FindFirstChild("Government")
    if gov and not gov:GetAttribute("currentFocus") then
        local democraticElections = gov.Focuses:FindFirstChild("Democratic Elections")
        local enhanceDefense = gov.Focuses:FindFirstChild("Enhance National Defense")
        local fortifyHomeland = gov.Focuses:FindFirstChild("Fortify the Homeland")
        local targetFocus = nil
        
        -- Respect PP safety buffer of 35 PP for starting focus
        if myCountryData:GetAttribute("politicalPower") > 35 then
            if democraticElections and democraticElections:GetAttribute("progress") < 1 then
                targetFocus = democraticElections
            elseif enhanceDefense and enhanceDefense:GetAttribute("progress") < 1 then
                targetFocus = enhanceDefense
            elseif fortifyHomeland and fortifyHomeland:GetAttribute("progress") < 1 then
                targetFocus = fortifyHomeland
            end
        end
        
        if targetFocus then
            local success = SafeInvoke(GetRemote("Government", "TryStartFocus"), targetFocus)
            if success then
                Log("🧠", "Started national focus: " .. targetFocus.Name)
            end
        end
    end
    
    -- Auto Research Slots
    for _, slot in ipairs(slots:GetChildren()) do
        if not slot.Value then
            local priorities = Brain:GetSmartTechPriority()
            local targetTech = nil
            
            for _, techName in ipairs(priorities) do
                local tInst = techs:FindFirstChild(techName)
                local price = tInst and tInst:GetAttribute("price") or 0
                local cashBuffer = GetDynamicCashBuffer(myCountryData)
                if tInst and tInst:GetAttribute("progress") < 1 and price <= (myCountryData:GetAttribute("money") - cashBuffer) then
                    local reqsUnlocked = true
                    for _, req in ipairs(ResearchCommon.techs[tInst.Name].required) do
                        if techs:FindFirstChild(req):GetAttribute("progress") < 1 then
                            reqsUnlocked = false
                            break
                        end
                    end
                    if reqsUnlocked then
                        targetTech = tInst
                        break
                    end
                end
            end
            
            if targetTech then
                if not targetTech:GetAttribute("purchased") then
                    SafeInvoke(GetRemote("Research", "TryPurchaseTech"), targetTech)
                end
                SafeFire(GetRemote("Research", "StartResearch"), targetTech)
                Stats.TechResearched = Stats.TechResearched + 1
                Log("🔬", "Started research: " .. targetTech.Name)
            end
        end
    end
end

function Executor:ManageEconomy()
    if not Config.AutoEconomy then return end
    
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    local money = myCountryData:GetAttribute("money")
    local manpower = myCountryData:GetAttribute("manpower")
    local pp = myCountryData:GetAttribute("politicalPower")
    
    local isAtWar = #World.MyEnemies > 0
    local cashBuffer = GetDynamicCashBuffer(myCountryData)
    
    -- Manpower Buy: Buy only if low on manpower (< 15,000), at war (or very low manpower < 5000), and cash/PP buffers are satisfied
    local shouldBuyManpower = (isAtWar and manpower < 15000) or (manpower < 5000)
    if shouldBuyManpower and pp > 35 and money - 4000 >= cashBuffer then
        local success = SafeInvoke(GetRemote("Army", "TryBuyManpower"))
        if success then
            Stats.ManpowerBought = Stats.ManpowerBought + 1
            Log("👥", "Purchased manpower (+10k)")
            manpower = myCountryData:GetAttribute("manpower")
            money = myCountryData:GetAttribute("money")
        end
    end
    
    -- Force troop targets training ahead of count
    local classes = myCountryData.Army.Classes
    local infantry = classes:FindFirstChild("Infantry")
    if infantry then
        local target = infantry:GetAttribute("target") or 0
        local count = infantry:GetAttribute("count") or 0
        if target - count < 15 and manpower > 15000 then -- Keep target 15 ahead
            SafeInvoke(GetRemote("Army", "TryIncreaseTarget"), infantry)
        end
    end
    local tanks = classes:FindFirstChild("Tanks")
    if tanks then
        local target = tanks:GetAttribute("target") or 0
        local count = tanks:GetAttribute("count") or 0
        if target - count < 8 and manpower > 20000 then -- Keep target 8 ahead
            SafeInvoke(GetRemote("Army", "TryIncreaseTarget"), tanks)
        end
    end
    
    -- Enforce Middle East Spawning border in Nizwa
    if World.MyCountry == "United Kingdom" and myCountryData.Army:GetAttribute("priorityCity") ~= "Nizwa" then
        SafeFire(GetRemote("Army", "SetPriorityCity"), "Nizwa")
    end
    
    -- Upgrade Port / Shipyard: Only if money after upgrade cost ($3,000) remains above the cash buffer
    if Config.AutoNavy and money - 3000 >= cashBuffer then
        for _, city in ipairs(myCountryData.Cities:GetChildren()) do
            if city:GetAttribute("isPort") then
                SafeInvoke(GetRemote("Economy", "TryUpgradeShipyard"), city)
            end
        end
    end
    
    -- Smart Factory Upgrades: Keep cashBuffer, limit to max 1 factory purchase per scan cycle to spend money gradually
    if money - 4000 >= cashBuffer then
        for _, city in ipairs(myCountryData.Cities:GetChildren()) do
            local currentFactories = city:GetAttribute("factories") or 0
            local maxFactories = city:GetAttribute("maxFactories") or 5
            if currentFactories < maxFactories and not city:GetAttribute("factoryBuildStart") then
                SafeFire(GetRemote("Cities", "PurchaseFactory"), city)
                Stats.FactoriesBuilt = Stats.FactoriesBuilt + 1
                Log("🏭", "Building factory in " .. city.Name)
                break -- Limit to 1 factory upgrade per scan cycle
            end
        end
    end
end

function Executor:ManageNavy()
    if not Config.AutoNavy then return end
    
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    -- Only buy ships if money after ship cost ($3,500) remains above the cash buffer
    local money = myCountryData:GetAttribute("money")
    local cashBuffer = GetDynamicCashBuffer(myCountryData)
    if money - 3500 < cashBuffer then return end
    
    local strategy = World.Strategy
    local shipName = "Destroyer I"
    if strategy == "BLITZ" or strategy == "EXPAND" then
        shipName = "Transport Ship I"
    end
    
    local ordered = 0
    for _, city in ipairs(myCountryData.Cities:GetChildren()) do
        if ordered >= 2 then break end
        
        if city:GetAttribute("isPort") then
            local success = SafeInvoke(GetRemote("Economy", "TryPurchaseShip"), city.Name, shipName)
            if success then
                Stats.ShipsPurchased = Stats.ShipsPurchased + 1
                Log("🚢", "Ordered " .. shipName .. " at " .. city.Name)
                ordered = ordered + 1
            end
        end
    end
end

function Executor:ManageAirForce()
    if not Config.AutoAirForce then return end
    
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    -- Only do air operations if money after cost ($4,000) remains above the cash buffer
    local money = myCountryData:GetAttribute("money")
    local cashBuffer = GetDynamicCashBuffer(myCountryData)
    if money - 4000 < cashBuffer then return end
    
    local actions = 0
    for _, city in ipairs(myCountryData.Cities:GetChildren()) do
        if actions >= 2 then break end
        
        if city:GetAttribute("isAirfield") then
            SafeInvoke(GetRemote("Planes", "TryBuildAiport"), city)
            SafeInvoke(GetRemote("Planes", "TryUpgradeAirfield"), city)
            Stats.AirfieldActions = Stats.AirfieldActions + 1
            actions = actions + 1
        end
    end
end

function Executor:ExpandAndConquer()
    if not Config.AutoExpand then return end
    
    local map = game.Workspace:WaitForChild("Map")
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    -- Allowed colors for pathfinding (Us + Enemies + Allies + Puppets + Master)
    local allowedColors = {[World.MyColor:ToHex()] = true}
    
    local activeEnemies = {}
    for _, enemy in ipairs(World.MyEnemies) do
        local enemyCountry = RS.Countries:FindFirstChild(enemy)
        if enemyCountry then
            local enemyColor = enemyCountry:GetAttribute("color")
            if enemyColor then
                allowedColors[enemyColor:ToHex()] = true
                activeEnemies[enemy] = true
            end
        end
    end
    
    for _, ally in ipairs(World.MyAllies) do
        local allyCountry = RS.Countries:FindFirstChild(ally)
        if allyCountry then
            local allyColor = allyCountry:GetAttribute("color")
            if allyColor then
                allowedColors[allyColor:ToHex()] = true
            end
        end
    end
    
    local puppets = myCountryData.Diplomacy:FindFirstChild("Puppets")
    if puppets then
        for _, p in ipairs(puppets:GetChildren()) do
            local pCountry = RS.Countries:FindFirstChild(p.Name)
            if pCountry then
                local pColor = pCountry:GetAttribute("color")
                if pColor then
                    allowedColors[pColor:ToHex()] = true
                end
            end
        end
    end
    local puppetOf = myCountryData:GetAttribute("puppetOf")
    if puppetOf then
        local pmCountry = RS.Countries:FindFirstChild(puppetOf)
        if pmCountry then
            local pmColor = pmCountry:GetAttribute("color")
            if pmColor then
                allowedColors[pmColor:ToHex()] = true
            end
        end
    end
    
    -- Compile enemy target tiles (Prioritize cities first, fallback to land tiles)
    local targetTiles = {}
    for _, enemy in ipairs(World.MyEnemies) do
        local enemyCountryFolder = RS.Countries:FindFirstChild(enemy)
        if enemyCountryFolder and enemyCountryFolder:FindFirstChild("Cities") then
            for _, city in ipairs(enemyCountryFolder.Cities:GetChildren()) do
                local tName = city:GetAttribute("tileName")
                local tile = tName and map:FindFirstChild(tName)
                if tile then
                    table.insert(targetTiles, tile)
                end
            end
        end
    end
    
    -- Fallback to all enemy land tiles if no city tiles found
    if #targetTiles == 0 then
        for _, tile in ipairs(map:GetChildren()) do
            if tile:IsA("BasePart") and not tile.Name:match("^Sea") then
                local tileColorHex = tile.Color:ToHex()
                local tileOwner = MapData.colorToCountry[tileColorHex]
                if tileOwner and activeEnemies[tileOwner] then
                    table.insert(targetTiles, tile)
                end
            end
        end
    end
    
    -- Fallback: If no war targets, group troops at priority city or capital
    if #targetTiles == 0 then
        local priorityCityName = myCountryData.Army:GetAttribute("priorityCity")
        local groupTile = nil
        if priorityCityName then
            local cityFolder = myCountryData.Cities:FindFirstChild(priorityCityName)
            if cityFolder then
                local tName = cityFolder:GetAttribute("tileName")
                if tName then groupTile = map:FindFirstChild(tName) end
            end
        end
        if not groupTile then
            for _, city in ipairs(myCountryData.Cities:GetChildren()) do
                if city:GetAttribute("isCapital") then
                    local tName = city:GetAttribute("tileName")
                    if tName then groupTile = map:FindFirstChild(tName) break end
                end
            end
        end
        
        if groupTile then
            for _, tInfo in ipairs(World.MyTroops) do
                local tile = map:FindFirstChild(tInfo.Tile)
                if tile and tile ~= groupTile then
                    local troopModel = tile:FindFirstChildWhichIsA("Model")
                    if troopModel then
                        local state = troopModel:GetAttribute("state")
                        local tTile = troopModel:GetAttribute("targetTile")
                        local isTroopIdle = (state == "Idle" or state == "Waiting") and (not tTile or tTile == "None" or tTile == "")
                        if isTroopIdle then
                        local path = computePath(tile, groupTile, allowedColors)
                        if path and #path > 1 then
                            local shortPath = {}
                            for i = 1, math.min(#path, 10) do
                                table.insert(shortPath, path[i])
                            end
                            SafeFire(GetRemote("Player", "MoveTroop"), shortPath)
                            Stats.TroopsMoved = Stats.TroopsMoved + 1
                        end
                    end
                end
            end
        end
        return
    end
    
    -- Command our idle troops
    for _, tInfo in ipairs(World.MyTroops) do
        local tile = map:FindFirstChild(tInfo.Tile)
        if tile then
            local troopModel = tile:FindFirstChildWhichIsA("Model")
            if troopModel then
                local state = troopModel:GetAttribute("state")
                local tTile = troopModel:GetAttribute("targetTile")
                local isTroopIdle = (state == "Idle" or state == "Waiting") and (not tTile or tTile == "None" or tTile == "")
                if isTroopIdle then
                local tColor = troopModel:GetAttribute("color")
                if tColor and tColor == World.MyColor then
                    -- Find closest reachable target
                    local sortedTargets = {}
                    for _, target in ipairs(targetTiles) do
                        local dist = (tile.Position - target.Position).Magnitude
                        table.insert(sortedTargets, {Tile = target, Dist = dist})
                    end
                    table.sort(sortedTargets, function(a, b) return a.Dist < b.Dist end)
                    
                    local path = nil
                    local chosenTarget = nil
                    for i = 1, math.min(#sortedTargets, 3) do -- Only check top 3 closest targets to save CPU
                        path = computePath(tile, sortedTargets[i].Tile, allowedColors)
                        if path then
                            chosenTarget = sortedTargets[i].Tile
                            break
                        end
                    end
                    
                    if path and #path > 1 then
                        local shortPath = {}
                        for i = 1, math.min(#path, 10) do
                            table.insert(shortPath, path[i])
                        end
                        SafeFire(GetRemote("Player", "MoveTroop"), shortPath)
                        Log("⚔️", "Moving troop towards enemy target " .. (chosenTarget:GetAttribute("cityName") or chosenTarget.Name))
                        Stats.TroopsMoved = Stats.TroopsMoved + 1
                    end
                end
            end
        end
    end
end

