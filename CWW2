                for _, c in ipairs(World.MyEnemies) do
                    if not lookup[c] then match = false break end
                end
            end
            if not match then
                SafeFire(GetRemote("Army", "ChangeTargetCountries"), armyFolder, World.MyEnemies)
            end
        end
    end
end

function Executor:ManageDiplomacy()
    if not Config.AutoDiplomacy then return end
    
    local map = game.Workspace:WaitForChild("Map")
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return end
    
    -- Request alliances (Max 3 active alliances)
    local activeAlliesCount = #World.MyAllies
    if activeAlliesCount < 3 then
        local allyTargets = Brain:FindBestAlly()
        for _, candidate in ipairs(allyTargets) do
            local allyName = candidate.Country
            local score = candidate.Score
            if score > 20 then
                local targetFolder = RS.Countries:FindFirstChild(allyName)
                if targetFolder then
                    -- Double check target active allies count (Max 3)
                    local targetAllies = targetFolder.Diplomacy:FindFirstChild("Allies")
                    local targetAlliesCount = targetAllies and #targetAllies:GetChildren() or 0
                    if targetAlliesCount < 3 then
                        -- Limit requests to once every 120 seconds per country to conserve political power
                        local lastSent = World.LastAllianceRequestSent[allyName] or 0
                        if os.clock() - lastSent > 120 then
                            World.LastAllianceRequestSent[allyName] = os.clock()
                            local success = SafeInvoke(GetRemote("Diplomacy", "TryRequestAlliance"), targetFolder)
                            if success then
                                Stats.AlliancesFormed = Stats.AlliancesFormed + 1
                                Log("🤝", "Alliance Request Sent → " .. allyName)
                                break -- Send only 1 alliance request per cycle to conserve PP
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- War Justifications & Declarations
    local justifications = myCountryData.Diplomacy:FindFirstChild("Justifications")
    local activeWarsCount = #World.MyEnemies
    local activeJustificationsCount = justifications and #justifications:GetChildren() or 0
    
    -- 1. Check completed justifications for border mobilization and win probability before declaring
    if justifications then
        for _, j in ipairs(justifications:GetChildren()) do
            local targetCountry = RS.Countries:FindFirstChild(j.Name)
            if targetCountry and not targetCountry:GetAttribute("isDead") then
                local isEnemy = myCountryData.Diplomacy.Enemies:FindFirstChild(j.Name)
                if not isEnemy and j:GetAttribute("completed") then
                    
                    -- Sequential War Gate: Only 1 active war at a time unless we are vastly superior
                    if activeWarsCount > 0 then
                        local currentEnemy = World.MyEnemies[1]
                        local currentEnemyPower = Brain:GetCountryPower(currentEnemy)
                        local myPower = Brain:GetMyPower()
                        if myPower < currentEnemyPower * 2.5 then
                            Log("🛡️", "Delaying war with " .. j.Name .. " - currently fighting " .. currentEnemy)
                            continue
                        end
                    end
                    
                    -- Win Probability check
                    local enemyPower = Brain:GetCountryPower(j.Name)
                    local myPower = Brain:GetMyPower()
                    local winProb = myPower / (enemyPower + myPower + 1)
                    if winProb < 0.55 then
                        Log("🛡️", string.format("Delaying war with %s - Win Prob too low (%.1f%% < 55%%)", j.Name, winProb * 100))
                        continue
                    end
                    
                    -- Pre-war Border Mobilization Check
                    local border = GetBorderTiles(j.Name)
                    if #border > 0 then
                        local troopCount, borderLookup = CountTroopsAtBorder(border)
                        if troopCount < 3 then
                            Log("🎖️", string.format("Mobilizing border for %s: %d/3 divisions present. Moving troops...", j.Name, troopCount))
                            
                            -- Move our idle troops to these border tiles!
                            local allowedColors = {[World.MyColor:ToHex()] = true}
                            for _, ally in ipairs(World.MyAllies) do
                                local allyCountry = RS.Countries:FindFirstChild(ally)
                                if allyCountry and allyCountry:GetAttribute("color") then
                                    allowedColors[allyCountry:GetAttribute("color"):ToHex()] = true
                                end
                            end
                            
                            for _, tInfo in ipairs(World.MyTroops) do
                                local tile = map:FindFirstChild(tInfo.Tile)
                                if tile then
                                    local troopModel = tile:FindFirstChildWhichIsA("Model")
                                    if troopModel then
                                        local state = troopModel:GetAttribute("state")
                                        local tTile = troopModel:GetAttribute("targetTile")
                                        local isTroopIdle = (state == "Idle" or state == "Waiting") and (not tTile or tTile == "None" or tTile == "")
                                        local tColor = troopModel:GetAttribute("color")
                                        if tColor and tColor == World.MyColor and isTroopIdle and not borderLookup[tInfo.Tile] then
                                            -- Pick a border tile and march there
                                            local targetBorderTile = border[math.random(1, #border)]
                                            local path = computePath(tile, targetBorderTile, allowedColors)
                                            if path and #path > 1 then
                                                local shortPath = {}
                                                for i = 1, math.min(#path, 10) do
                                                    table.insert(shortPath, path[i])
                                                end
                                                SafeFire(GetRemote("Player", "MoveTroop"), shortPath)
                                                Stats.TroopsMoved = Stats.TroopsMoved + 1
                                            end
                                        end
                                    end
                                end
                            end
                            continue -- Delay war declaration until troops arrive
                        end
                    end
                    
                    -- Mobilization and gate checks passed. Declare war!
                    local success = SafeInvoke(GetRemote("Diplomacy", "TryDeclareWar"), targetCountry)
                    if success then
                        Stats.WarsDeclared = Stats.WarsDeclared + 1
                        Log("⚔️", "WAR DECLARED ON " .. j.Name:upper() .. " (Mobilization Complete!)")
                    end
                end
            end
        end
    end
    
    -- 2. Send diplomatic demands to justification targets to negotiate peaceful vassalage
    if justifications then
        for _, j in ipairs(justifications:GetChildren()) do
            local targetName = j.Name
            local targetCountry = RS.Countries:FindFirstChild(targetName)
            if targetCountry and not targetCountry:GetAttribute("isDead") then
                local isEnemy = myCountryData.Diplomacy.Enemies:FindFirstChild(targetName)
                if not isEnemy then
                    -- Limit demands to once every 60 seconds per country to avoid spamming
                    local lastSent = World.LastDemandSent[targetName] or 0
                    if os.clock() - lastSent > 60 then
                        World.LastDemandSent[targetName] = os.clock()
                        
                        local targetMoney = targetCountry:GetAttribute("money") or 0
                        local targetManpower = targetCountry:GetAttribute("manpower") or 0
                        
                        -- Calculate demand terms:
                        -- We demand they become our puppet, plus 20% of their money and manpower
                        local demandMoney = math.floor(targetMoney * 0.20)
                        local demandManpower = math.floor(targetManpower * 0.20)
                        
                        local treatyData = {
                            money = demandMoney,
                            manpower = demandManpower,
                            puppet = true,
                            takeTiles = {},
                            giveTiles = {},
                            treatyType = "Demand"
                        }
                        
                        local success = SafeInvoke(GetRemote("Diplomacy", "TrySendTreaty"), targetCountry, treatyData)
                        if success then
                            Log("📋", "Sent Vassalage Demand → " .. targetName .. " (Negotiating...)")
                        end
                    end
                end
            end
        end
    end
    
    -- 3. Dynamically justify on land neighbors first
    if activeWarsCount == 0 and activeJustificationsCount == 0 then
        local targets = GetPotentialTargets()
        for _, target in ipairs(targets) do
            local name = target.Name
            local targetCountry = target.Folder
            
            local isEnemy = myCountryData.Diplomacy.Enemies:FindFirstChild(name)
            local isJustifying = justifications and justifications:FindFirstChild(name)
            
            if not isEnemy and not isJustifying then
                if myCountryData:GetAttribute("politicalPower") > 50 then
                    local success = SafeInvoke(GetRemote("Diplomacy", "TryJustifyWar"), targetCountry)
                    if success then
                        Log("📋", "Started war justification → " .. name)
                        activeJustificationsCount = activeJustificationsCount + 1
                        break -- Just justify on one target at a time, then wait
                    end
                end
            end
        end
    end
end

