-- ══════════════════════════════════════════════════════════════
local function GetTreatyNetValue(senderName, data)
    local value = data.money or 0
    value = value + (data.manpower or 0) * 0.1
    
    if data.giveTiles then
        value = value - #data.giveTiles * 150
    end
    if data.takeTiles then
        value = value + #data.takeTiles * 150
    end
    
    if data.puppet then
        if data.treatyType == "Demand" then
            -- They demand we become their puppet (disastrous)
            value = value - 50000
        elseif data.treatyType == "Peace" then
            -- They surrender to become our puppet (fantastic)
            value = value + 20000
        end
    end
    return value
end

local function EvaluatePeaceTreaty(senderName, data)
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if not myCountryData then return "Reject" end
    
    local myPower = Brain:GetMyPower()
    local senderPower = Brain:GetCountryPower(senderName)
    local myCitiesCount = #World.MyCities
    
    local isEnemy = myCountryData.Diplomacy.Enemies:FindFirstChild(senderName) ~= nil
    local netValue = GetTreatyNetValue(senderName, data)
    
    -- Emergency survival condition:
    -- If we are losing badly (cities < 5) and the enemy is much stronger,
    -- we accept negative net value treaties (up to -10,000) to survive.
    local survivalThreshold = 0
    if isEnemy and myCitiesCount < 5 and senderPower > myPower * 1.5 then
        survivalThreshold = -10000
    end
    
    if netValue >= survivalThreshold then
        return "Accept"
    else
        return "Reject"
    end
end

local function SetupTreatyListener()
    local TreatyResponse = RS:WaitForChild("Diplomacy"):WaitForChild("TreatyResponse")
    local activeMenu = PlayerGui:WaitForChild("GameGui"):WaitForChild("Menus")
    
    TreatyResponse.OnClientEvent:Connect(function(treatyInst)
        local dataStr = treatyInst:GetAttribute("data")
        local sender = treatyInst.Value
        
        if dataStr and sender then
            local data = game:GetService("HttpService"):JSONDecode(dataStr)
            local senderName = sender.Name
            
            local decision = EvaluatePeaceTreaty(senderName, data)
            if decision == "Accept" then
                TreatyResponse:FireServer(treatyInst, true)
                Stats.TreatiesAccepted = Stats.TreatiesAccepted + 1
                Log("🤝", "Auto-Accepted Treaty from " .. senderName)
            else
                TreatyResponse:FireServer(treatyInst, false)
                Stats.TreatiesRejected = Stats.TreatiesRejected + 1
                Log("❌", "Auto-Rejected Treaty from " .. senderName)
            end
            
            if activeMenu:GetAttribute("activeMenu") == "IncomingTreatyMenu" then
                activeMenu:SetAttribute("activeMenu", "")
            end
        end
    end)
end

