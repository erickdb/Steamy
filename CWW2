local function GetBorderTiles(targetCountryName)
    local borderTiles = {}
    local map = game.Workspace:FindFirstChild("Map")
    if not map then return borderTiles end
    
    local targetFolder = RS.Countries:FindFirstChild(targetCountryName)
    if not targetFolder then return borderTiles end
    local targetColorHex = targetFolder:GetAttribute("color"):ToHex()
    
    for _, tile in ipairs(map:GetChildren()) do
        if tile:IsA("BasePart") and not tile.Name:match("^Sea") then
            if tile.Color == World.MyColor then
                local nList = neighbours[tile]
                if nList then
                    for _, n in ipairs(nList) do
                        if not n.Name:match("^Sea") and n.Color:ToHex() == targetColorHex then
                            table.insert(borderTiles, tile)
                            break
                        end
                    end
                end
            end
        end
    end
    return borderTiles
end

local function CountTroopsAtBorder(borderTiles)
    local count = 0
    local borderLookup = {}
    
    for _, tile in ipairs(borderTiles) do
        borderLookup[tile.Name] = tile
        local nList = neighbours[tile]
        if nList then
            for _, n in ipairs(nList) do
                if not n.Name:match("^Sea") and n.Color == World.MyColor then
                    borderLookup[n.Name] = n
                end
            end
        end
    end
    
    for _, tInfo in ipairs(World.MyTroops) do
        if borderLookup[tInfo.Tile] then
            count = count + 1
        end
    end
    return count, borderLookup
end

