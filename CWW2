-- MAIN AI CYCLE
-- ══════════════════════════════════════════════════════════════
local function RunAICycle()
    local scanned = Scanner:FullScan()
    if not scanned then
        Log("❌", "Failed to scan - no country selected")
        return
    end
    
    local strategy = Brain:EvaluateStrategy()
    
    Executor:ManageArmies()
    task.wait(0.4)
    
    -- Run dynamic diplomacy on every cycle for mobilization / declarations
    Executor:ManageDiplomacy()
    task.wait(0.4)
    
    if World.TurnNumber % 2 == 0 then
        Executor:ManageProduction()
    end
    
    if World.TurnNumber % 2 == 1 then
        Executor:ManageResearch()
    end
    
    Executor:ManageEconomy()
    task.wait(0.3)
    
    Executor:ExpandAndConquer()
    task.wait(0.3)
    
    if World.TurnNumber % 3 == 1 then
        Executor:ManageNavy()
    end
    
    if World.TurnNumber % 3 == 2 then
        Executor:ManageAirForce()
    end
    
    Log("📊", string.format("Scan #%d | Adam: %s | Loss: %.4f | Cities: %d",
        World.TurnNumber, strategy, NeuralStrategyNet.lastLoss, #World.MyCities))
end

