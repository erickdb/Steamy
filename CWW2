        elseif strategy == "DEFEND" then
            order = "Defend"
        end
        
        for _, armyFolder in ipairs(armyList) do
            SafeFire(GetRemote("Army", "AutoAssignTroopsToArmy"), armyFolder.Name)
            
            if not armyFolder:GetAttribute("replenishTroops") then
