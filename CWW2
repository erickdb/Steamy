-- CUSTOM NEURAL NETWORK ENGINE (FEEDFORWARD + ADAM OPTIMIZER)
-- ══════════════════════════════════════════════════════════════
local NeuralNetwork = {}
NeuralNetwork.__index = NeuralNetwork

local function relu(x)
    return math.max(0.0, x)
end

local function reluDerivative(x)
    return x > 0 and 1.0 or 0.0
end

local function softmax(vector)
    local maxVal = -999999
    for _, v in ipairs(vector) do
        if v > maxVal then maxVal = v end
    end
    
    local sum = 0
    local expVec = {}
    for i, v in ipairs(vector) do
        local ev = math.exp(v - maxVal)
        expVec[i] = ev
        sum = sum + ev
    end
    
    for i = 1, #vector do
        expVec[i] = expVec[i] / (sum == 0 and 1 or sum)
    end
    return expVec
end

function NeuralNetwork.new(layerSizes)
    local self = setmetatable({}, NeuralNetwork)
    self.layerSizes = layerSizes
    self.layers = #layerSizes
    self.weights = {}
    self.biases = {}
    
    -- He-initialization for weights, zeros for biases
    local rand = math.random
    for i = 1, self.layers - 1 do
        local nIn = layerSizes[i]
        local nOut = layerSizes[i+1]
        local w = {}
        local b = {}
        
        local stddev = math.sqrt(2.0 / nIn)
        for row = 1, nOut do
            w[row] = {}
            for col = 1, nIn do
                -- Box-Muller Gaussian noise
                local u1 = rand()
                local u2 = rand()
                if u1 == 0 then u1 = 0.0001 end
                local z0 = math.sqrt(-2.0 * math.log(u1)) * math.cos(2.0 * math.pi * u2)
                w[row][col] = z0 * stddev
            end
            b[row] = 0.0
        end
        self.weights[i] = w
        self.biases[i] = b
    end
    
    -- Adam parameters initialization
    self.beta1 = 0.9
    self.beta2 = 0.999
    self.eps = 1e-8
    self.mW = {}
    self.vW = {}
    self.mB = {}
    self.vB = {}
    for i = 1, self.layers - 1 do
        local nIn = layerSizes[i]
        local nOut = layerSizes[i+1]
        self.mW[i] = {}
        self.vW[i] = {}
        self.mB[i] = {}
        self.vB[i] = {}
        for row = 1, nOut do
            self.mW[i][row] = {}
            self.vW[i][row] = {}
            self.mB[i][row] = 0.0
            self.vB[i][row] = 0.0
            for col = 1, nIn do
                self.mW[i][row][col] = 0.0
                self.vW[i][row][col] = 0.0
            end
        end
    end
    
    self.t = 0
    self.epochs = 0
    self.lastLoss = 0.0
    return self
end

function NeuralNetwork:Forward(inputs)
    self.activations = {[1] = inputs}
    self.zs = {}
    
    local current = inputs
    for i = 1, self.layers - 1 do
        local w = self.weights[i]
        local b = self.biases[i]
        local nextActivation = {}
        local nextZ = {}
        
        for row = 1, #w do
            local sum = b[row]
            for col = 1, #w[row] do
                sum = sum + w[row][col] * current[col]
            end
            nextZ[row] = sum
            if i == self.layers - 1 then
                nextActivation[row] = sum
            else
                nextActivation[row] = relu(sum)
            end
        end
        
        self.zs[i] = nextZ
        if i == self.layers - 1 then
            self.activations[i+1] = softmax(nextActivation)
        else
            self.activations[i+1] = nextActivation
        end
        current = self.activations[i+1]
    end
    
    return current
end

function NeuralNetwork:Backward(targets, learningRate)
    local deltas = {}
    local L = self.layers
    
    -- Output layer delta (Softmax + Cross Entropy)
    local outActivation = self.activations[L]
    local outDelta = {}
    local loss = 0.0
    for i = 1, #outActivation do
        outDelta[i] = outActivation[i] - targets[i]
        local t = targets[i]
        if t > 0 then
            loss = loss - t * math.log(math.max(1e-15, outActivation[i]))
        end
    end
    self.lastLoss = loss
    deltas[L-1] = outDelta
    
    -- Backpropagate error through hidden layers
    for i = L - 2, 1, -1 do
        local wNext = self.weights[i+1]
        local deltaNext = deltas[i+1]
        local zCurr = self.zs[i]
        local deltaCurr = {}
        
        for col = 1, #zCurr do
            local sum = 0.0
            for row = 1, #wNext do
                sum = sum + wNext[row][col] * deltaNext[row]
            end
            deltaCurr[col] = sum * reluDerivative(zCurr[col])
        end
        deltas[i] = deltaCurr
    end
    
    -- Update weights and biases using Adam optimizer
    self.t = self.t + 1
    local alpha = learningRate * math.sqrt(1.0 - self.beta2^self.t) / (1.0 - self.beta1^self.t)
    
    for i = 1, L - 1 do
        local w = self.weights[i]
        local b = self.biases[i]
        local delta = deltas[i]
        local act = self.activations[i]
        
        local mW = self.mW[i]
        local vW = self.vW[i]
        local mB = self.mB[i]
        local vB = self.vB[i]
        
        for row = 1, #w do
            -- Bias update
            local gB = delta[row]
            mB[row] = self.beta1 * mB[row] + (1.0 - self.beta1) * gB
            vB[row] = self.beta2 * vB[row] + (1.0 - self.beta2) * gB^2
            b[row] = b[row] - alpha * mB[row] / (math.sqrt(vB[row]) + self.eps)
            
            -- Weight update
            for col = 1, #w[row] do
                local gW = delta[row] * act[col]
                mW[row][col] = self.beta1 * mW[row][col] + (1.0 - self.beta1) * gW
                vW[row][col] = self.beta2 * vW[row][col] + (1.0 - self.beta2) * gW^2
                w[row][col] = w[row][col] - alpha * mW[row][col] / (math.sqrt(vW[row][col]) + self.eps)
            end
        end
    end
    
    self.epochs = self.epochs + 1
    return loss
end

