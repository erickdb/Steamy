local Scanner = {}

function Scanner:GetMyCountry()
    local ls = LP:FindFirstChild("leaderstats")
    if ls then
        local c = ls:FindFirstChild("Country")
        if c then return c.Value end
    end
    return nil
end

function Scanner:ScanCountries()
    local countries = RS:FindFirstChild("Countries")
    if not countries then return end
    
    World.Countries = {}
    World.MyEnemies = {}
    World.MyAllies = {}
    
    for _, c in pairs(countries:GetChildren()) do
        if not c:IsA("ObjectValue") then continue end
        
        local info = {
            Name = c.Name,
            Owner = nil,
            IsPlayer = false,
            Cities = {},
            CityCount = 0,
            Enemies = {},
            Allies = {},
            Puppets = {},
            ArmyGroups = 0,
            HasTanks = false,
            HasAntiTank = false,
            Power = 0,
            TileCount = 0,
            TroopCount = 0,
        }
        
        pcall(function()
            if c.Value then
                info.Owner = c.Value.Name
                info.IsPlayer = true
            end
        end)
        
        local cities = c:FindFirstChild("Cities")
        if cities then
            info.CityCount = #cities:GetChildren()
            for _, city in pairs(cities:GetChildren()) do
                table.insert(info.Cities, city.Name)
            end
        end
        
        local diplo = c:FindFirstChild("Diplomacy")
        if diplo then
            local enemies = diplo:FindFirstChild("Enemies")
            if enemies then
                for _, e in pairs(enemies:GetChildren()) do
                    table.insert(info.Enemies, e.Name)
                end
            end
            local allies = diplo:FindFirstChild("Allies")
            if allies then
                for _, a in pairs(allies:GetChildren()) do
                    table.insert(info.Allies, a.Name)
                end
            end
            local puppets = diplo:FindFirstChild("Puppets")
            if puppets then
                for _, p in pairs(puppets:GetChildren()) do
                    table.insert(info.Puppets, p.Name)
                end
            end
        end
        
        local army = c:FindFirstChild("Army")
        if army then
            local armies = army:FindFirstChild("Armies")
            if armies then info.ArmyGroups = #armies:GetChildren() end
            local classes = army:FindFirstChild("Classes")
            if classes then
                info.HasTanks = classes:FindFirstChild("Tanks") ~= nil
                info.HasAntiTank = classes:FindFirstChild("AntiTank") ~= nil
            end
        end
        
        info.Power = info.CityCount * 10
            + info.ArmyGroups * 15
            + (info.HasTanks and 20 or 0)
            + (info.HasAntiTank and 10 or 0)
            + (info.IsPlayer and 25 or 0)
            + #info.Allies * 8
            + #info.Puppets * 5
        
        World.Countries[c.Name] = info
        
        if c.Name == World.MyCountry then
            World.MyCities = info.Cities
            for _, e in ipairs(info.Enemies) do
                table.insert(World.MyEnemies, e)
            end
            for _, a in ipairs(info.Allies) do
                table.insert(World.MyAllies, a)
            end
        end
    end
end

function Scanner:ScanTiles()
    local map = game.Workspace:FindFirstChild("Map")
    if not map then return end
    
    World.TileData = {}
    World.MyTileCount = 0
    World.MyTroops = {}
    
    local myCountryData = RS.Countries:FindFirstChild(World.MyCountry)
    if myCountryData then
        World.MyColor = myCountryData:GetAttribute("color")
    end
    
    for _, tile in pairs(map:GetChildren()) do
        if not tile:IsA("BasePart") then continue end
        
        local terrain = tile:GetAttribute("terrain") or "plains"
        local region = tile:GetAttribute("region") or ""
        local airRegion = tile:GetAttribute("airRegion") or ""
        
        local tileInfo = {
            Name = tile.Name,
            Position = tile.Position,
            Color = tile.Color,
            Terrain = terrain,
            Region = region,
            AirRegion = airRegion,
            Troops = {},
            IsMyTile = false,
        }
        
        for _, child in pairs(tile:GetChildren()) do
            if child:IsA("Model") then
                local name = child.Name
                if name:find("Infantry") or name:find("Tank") or name:find("AntiTank") or name:find("Artillery") then
                    table.insert(tileInfo.Troops, {
                        Name = name,
                        Type = name:match("(%a+)%d*"),
                        Level = tonumber(name:match("%d+")) or 1,
                    })
                end
            end
        end
        
        World.TileData[tile.Name] = tileInfo
        
        if World.MyColor and tile.Color == World.MyColor then
            tileInfo.IsMyTile = true
            World.MyTileCount = World.MyTileCount + 1
            for _, troop in ipairs(tileInfo.Troops) do
                table.insert(World.MyTroops, {
                    Tile = tile.Name,
                    Troop = troop,
                    Region = region,
                    Terrain = terrain,
                })
            end
        end
    end
end

