local function GetDynamicCashBuffer(myCountryData)
    local isAtWar = #World.MyEnemies > 0
    local totalMoney = myCountryData:GetAttribute("money") or 0
    if isAtWar then
        -- At war: keep 40% of treasury, minimum $8,000
        return math.max(8000, math.floor(totalMoney * 0.40))
    else
        -- At peace: keep 25% of treasury, minimum $5,000
        return math.max(5000, math.floor(totalMoney * 0.25))
    end
end

