local Brain = {}

function Brain:GetMyPower()
    local data = World.Countries[World.MyCountry]
    return data and data.Power or 0
end

function Brain:GetCountryPower(name)
    local data = World.Countries[name]
    return data and data.Power or 0
end

function Brain:GetTotalEnemyPower()
    local total = 0
    for _, enemy in ipairs(World.MyEnemies) do
        total = total + self:GetCountryPower(enemy)
    end
    return total
end

function Brain:GetTotalAllyPower()
    local total = self:GetMyPower()
    for _, ally in ipairs(World.MyAllies) do
        total = total + self:GetCountryPower(ally)
    end
    return total
end

function Brain:GetExpertHeuristics()
    local myPower = self:GetMyPower()
    local enemyPower = self:GetTotalEnemyPower()
    local allyPower = self:GetTotalAllyPower()
    local myCities = #World.MyCities
    local enemyCount = #World.MyEnemies
    
    local target = {0, 0, 0, 0} -- BLITZ, DEFEND, EXPAND, CONSOLIDATE
    
    if enemyCount == 0 then
        if myCities >= Config.MinCitiesForWar then
            target[3] = 1.0 -- EXPAND
        else
            target[4] = 1.0 -- CONSOLIDATE
        end
    elseif enemyPower > allyPower * 1.6 then
        target[2] = 1.0 -- DEFEND
    elseif enemyCount >= 3 and enemyPower > allyPower * 0.8 then
        target[2] = 1.0 -- DEFEND
    elseif allyPower > enemyPower * Config.AttackPowerRatio then
        target[1] = 1.0 -- BLITZ
    else
        target[3] = 1.0 -- EXPAND
    end
    
    return target
end

