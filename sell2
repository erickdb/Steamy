local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local Networking = require(game.ReplicatedStorage.SharedModules.Networking)

local enabled = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "ToggleGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 180, 0, 50)
frame.Position = UDim2.new(0, 10, 0.5, -25)
frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
frame.BorderSizePixel = 0
frame.Parent = gui

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 30, 0, 30)
button.Position = UDim2.new(0, 10, 0, 10)
button.BorderSizePixel = 0
button.AutoButtonColor = false
button.TextColor3 = Color3.new(1, 1, 1)
button.Parent = frame

local label = Instance.new("TextLabel")
label.Size = UDim2.new(1, -50, 1, 0)
label.Position = UDim2.new(0, 45, 0, 0)
label.BackgroundTransparency = 1
label.TextColor3 = Color3.new(1, 1, 1)
label.Font = Enum.Font.SourceSansBold
label.TextSize = 18
label.Parent = frame

-- update UI
local function updateState()
	if enabled then
		button.Text = "☑"
		button.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
		label.Text = "Auto Sell ON"
	else
		button.Text = "☐"
		button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
		label.Text = "Auto Sell OFF"
	end
end

-- toggle
button.MouseButton1Click:Connect(function()
	enabled = not enabled
	updateState()
end)

updateState()

-- 🔥 DRAG SYSTEM
local dragging = false
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

frame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

-- AUTO SELL LOOP
task.spawn(function()
	while true do
		if enabled then
			local success, result = pcall(function()
				return Networking.NPCS.SellAll:Fire()
			end)

			if success and result then
				if type(result) == "table" then
					for k, v in pairs(result) do
						print(k, v)
					end
				end
			end
		end

		task.wait(0.5)
	end
end)
